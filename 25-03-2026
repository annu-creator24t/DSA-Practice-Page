Count Binary String without Consecutive One's

<------Recursive Solution------>

class Solution {
    static final int MOD = 1000000007;

    public static int countStrings(int n) {
        if (n == 0) return 1;
        if (n == 1) return 2;

        return (int)((countStrings(n - 1) + countStrings(n - 2)) % MOD);
    }

    public static void main(String[] args) {
        int n = 6;
        System.out.println(countStrings(n));
    }
}
Time: O(2^n)
Space: O(n)


