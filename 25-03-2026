class Solution {
    static final int MOD = 1000000007;

    public static void main(String[] args) {
        int n = 6;

        if (n == 0) {
            System.out.println(1);
            return;
        }

        int prev2 = 1; // f(0)
        int prev1 = 2; // f(1)

        for (int i = 2; i <= n; i++) {
            int curr = (prev1 + prev2) % MOD;
            prev2 = prev1;
            prev1 = curr;
        }

        System.out.println(prev1);
    }
}
Time: O(n)
Space: O(1)


LeetCode 198-  House Robber I

<------Recursive Code------->
class Solution {
    public static int robFrom(int[] nums, int index) {
        if(index >= nums.length) {
            return 0;
        }
        int inlcude = nums[index] + robFrom(nums, index + 2);
        int exlcude = robFrom(nums, index + 1);

        return Math.max(inlcude, exlcude);
    }

    public int rob(int[] nums) {
        return robFrom(nums, 0);
    }
}


<-------Memoization----------> 
class Solution {

    public static int robFrom(int[] nums, int index, int[] dp){
        if(index >= nums.length) {
            return 0;
        }
        if(dp[index] != -1) return dp[index];  
        int include = nums[index] + robFrom(nums, index + 2,dp);
        int exclude = robFrom(nums, index + 1, dp);
        
        return dp[index] = Math.max(include, exclude);
    }

    public int rob(int[] nums) {

        int[] dp = new int[nums.length];
        Arrays.fill(dp, -1);
        return robFrom(nums, 0, dp); 
    }
}


