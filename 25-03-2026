import java.util.*;

class Solution {
    static final int MOD = 1000000007;

    static int solve(int n, int[] dp) {
        if (n == 0) return 1;
        if (n == 1) return 2;

        if (dp[n] != -1) return dp[n];

        return dp[n] = (solve(n - 1, dp) + solve(n - 2, dp)) % MOD;
    }

    public static void main(String[] args) {
        int n = 6;
        int[] dp = new int[n + 1];
        Arrays.fill(dp, -1);

        System.out.println(solve(n, dp));
    }
}
Time: O(n)
Space: O(n)



